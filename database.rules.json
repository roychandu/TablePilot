              ".write": "$uid === auth.uid",
              "$feedbackId": {
                ".read": "$uid === auth.uid",
                ".write": "$uid === auth.uid"
              }
            }
          }
        },
        "reports": {
          ".read": "$uid === auth.uid",
          ".write": "$uid === auth.uid",
