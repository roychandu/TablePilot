{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        "profile": {
          ".read": "$uid === auth.uid",
          ".write": "$uid === auth.uid"
        },
        "orders": {
          ".read": "auth != null",
          ".write": "$uid === auth.uid",
          "$orderId": {
            ".read": "auth != null",
            ".write": "$uid === auth.uid",
            "bills": {
              ".read": "$uid === auth.uid",
              ".write": "$uid === auth.uid",
              "$billId": {
                ".read": "$uid === auth.uid",
                ".write": "$uid === auth.uid"
              }
            },
            "feedback": {
