            ".read": "auth != null",
            ".write": "$uid === auth.uid"
          }
        },
        "offers": {
          ".read": "$uid === auth.uid",
          ".write": "$uid === auth.uid",
          "$offerId": {
            ".read": "$uid === auth.uid",
            ".write": "$uid === auth.uid"
          }
        },
        "menu": {
          ".read": "$uid === auth.uid",
          ".write": "$uid === auth.uid"
        },
